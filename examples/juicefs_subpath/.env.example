# ── 腾讯云凭证 ────────────────────────────────────────────────────────────────
export TENCENTCLOUD_SECRET_ID=<your-secret-id>
export TENCENTCLOUD_SECRET_KEY=<your-secret-key>

# ── AGS 服务端点 ──────────────────────────────────────────────────────────────
export AGS_REGION=ap-beijing
export AGS_ENDPOINT=ags.tencentcloudapi.com
export AGS_DATA_PLANE_DOMAIN=tencentags.com

# ── JuiceFS 存储源 ────────────────────────────────────────────────────────────
# JuiceFS 元数据引擎内网地址（需与沙箱在同一 VPC）
export JUICEFS_BASE_URL=http://<juicefs-metadata-engine-ip>:<port>
export JUICEFS_VOLUME_NAME=<volume-name>
export JUICEFS_TOKEN=<juicefs-access-token>

# ── VPC 网络配置 ──────────────────────────────────────────────────────────────
# 子网和安全组需与 JuiceFS 元数据引擎在同一 VPC
export AGS_SUBNET_ID=subnet-xxxxxxxx
export AGS_SECURITY_GROUP_ID=sg-xxxxxxxx

# ── 沙箱配置 ──────────────────────────────────────────────────────────────────
# CAM 角色 ARN（用于拉取私有镜像和挂载存储）
export AGS_ROLE_ARN=qcs::cam::uin/<uin>:roleName/<role-name>
# 包含 envd 的容器镜像地址
export AGS_IMAGE=ccr.ccs.tencentyun.com/<namespace>/<repo>:<tag>
# JuiceFS 卷在沙箱内的挂载路径
export AGS_MOUNT_PATH=/mnt/juicefs
